{
  "name": "bartab",
  "version": "0.1.0",
  "description": "A spending tab for your coding agent. Local-first cost + bloat receipts for Claude Code and Codex.",
  "license": "MIT",
  "author": "Dor Amir <amirdor@gmail.com>",
  "homepage": "https://doramirdor.github.io/bartab/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doramirdor/bartab.git"
  },
  "bugs": {
    "url": "https://github.com/doramirdor/bartab/issues"
  },
  "type": "commonjs",
  "bin": {
    "bartab": "bin/bartab.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node scripts/e2e.js && node scripts/e2e-codex.js",
    "bartab": "node bin/bartab.js"
  },
  "keywords": [
    "claude-code",
    "codex",
    "cli",
    "ai-agents",
    "cost",
    "tokens",
    "observability",
    "hooks",
    "devtools"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
